<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>Systems & Decision Toolkit</title>
<style>
body {
    margin: 0;
    font-family: 'Segoe UI', sans-serif;
    background: radial-gradient(circle at top, #0b1a2a, #050d18);
    color: #e6f1ff;
}

.container {
    text-align: center;
    padding: 60px 20px;
}

h1 {
    font-size: 40px;
    letter-spacing: 2px;
    text-shadow: 0 0 15px #00eaff;
}

.subtitle {
    color: #7aa0c4;
    margin-bottom: 40px;
    font-size: 14px;
}

.grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 25px;
    max-width: 1100px;
    margin: auto;
}

.card {
    background: rgba(255,255,255,0.03);
    border-radius: 15px;
    padding: 20px;
    border: 1px solid rgba(0, 234, 255, 0.2);
    transition: 0.3s ease;
}

.card:hover {
    transform: translateY(-8px);
    box-shadow: 0 0 20px rgba(0,234,255,0.4);
}

.card h3 {
    margin-bottom: 15px;
    color: #00eaff;
    font-size: 16px;
}

.tags {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
}

.tag {
    background: rgba(0,234,255,0.1);
    border: 1px solid rgba(0,234,255,0.3);
    padding: 6px 12px;
    border-radius: 20px;
    font-size: 13px;
}
</style>
</head>

<body>

<div class="container">
    <h1>Systems & Decision Toolkit</h1>
    <div class="subtitle">ENGINEERING • ANALYTICS • EXECUTION</div>

    <div class="grid">

        <div class="card">
            <h3>Programming & Analysis</h3>
            <div class="tags">
                <div class="tag">Python</div>
                <div class="tag">C</div>
                <div class="tag">SQL</div>
                <div class="tag">Excel</div>
            </div>
        </div>

        <div class="card">
            <h3>Operations & Supply Chain</h3>
            <div class="tags">
                <div class="tag">Supply Chain Analytics</div>
                <div class="tag">Production Planning</div>
                <div class="tag">Line Balancing</div>
                <div class="tag">Process Optimization</div>
            </div>
        </div>

        <div class="card">
            <h3>Simulation & Design</h3>
            <div class="tags">
                <div class="tag">SolidWorks</div>
                <div class="tag">ANSYS</div>
                <div class="tag">AutoCAD</div>
                <div class="tag">CATIA</div>
            </div>
        </div>

        <div class="card">
            <h3>Data & Business Tools</h3>
            <div class="tags">
                <div class="tag">Excel</div>
                <div class="tag">Google Sheets</div>
                <div class="tag">Canva</div>
                <div class="tag">PowerPoint</div>
            </div>
        </div>

        <div class="card">
            <h3>Engineering Applications</h3>
            <div class="tags">
                <div class="tag">FEA</div>
                <div class="tag">QFD</div>
                <div class="tag">Product Development</div>
                <div class="tag">Material Selection</div>
            </div>
        </div>

        <div class="card">
            <h3>Communication & Creativity</h3>
            <div class="tags">
                <div class="tag">Content Writing</div>
                <div class="tag">Storytelling</div>
                <div class="tag">Presentations</div>
            </div>
        </div>

    </div>
</div>

</body>
</html>
