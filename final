<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>Systems & Decision Toolkit</title>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600&display=swap" rel="stylesheet">

<style>
body {
    margin: 0;
    font-family: 'Inter', sans-serif;
    background: radial-gradient(circle at top, #07111f, #02060d);
    color: #eaf6ff;
}

/* ===== Container ===== */
.container {
    text-align: center;
    padding: 80px 20px;
}

/* ===== Title ===== */
h1 {
    font-size: 42px;
    font-weight: 600;
    letter-spacing: 2px;
    background: linear-gradient(90deg, #00eaff, #6a8cff);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
}

.underline {
    width: 80px;
    height: 3px;
    margin: 12px auto 20px;
    background: linear-gradient(90deg, #00eaff, #6a8cff);
    border-radius: 2px;
    animation: glow 2s infinite alternate;
}

@keyframes glow {
    from { box-shadow: 0 0 5px #00eaff; }
    to { box-shadow: 0 0 20px #6a8cff; }
}

.subtitle {
    color: #7da2c7;
    font-size: 14px;
    margin-bottom: 50px;
    letter-spacing: 1px;
}

/* ===== Grid ===== */
.grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 30px;
    max-width: 1100px;
    margin: auto;
}

/* ===== Cards ===== */
.card {
    background: rgba(255,255,255,0.03);
    backdrop-filter: blur(12px);
    border-radius: 18px;
    padding: 25px;
    border: 1px solid rgba(0,234,255,0.15);
    transition: all 0.35s ease;
    position: relative;
    overflow: hidden;
}

.card::before {
    content: "";
    position: absolute;
    inset: 0;
    border-radius: 18px;
    padding: 1px;
    background: linear-gradient(120deg, transparent, #00eaff, transparent);
    -webkit-mask:
      linear-gradient(#000 0 0) content-box,
      linear-gradient(#000 0 0);
    -webkit-mask-composite: xor;
    opacity: 0;
    transition: 0.4s;
}

.card:hover::before {
    opacity: 1;
}

.card:hover {
    transform: translateY(-10px) scale(1.02);
    box-shadow: 0 0 25px rgba(0,234,255,0.25);
}

/* ===== Card Title ===== */
.card h3 {
    margin-bottom: 18px;
    font-size: 16px;
    color: #00eaff;
    display: flex;
    align-items: center;
    gap: 8px;
}

/* ===== Tags ===== */
.tags {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
}

.tag {
    background: rgba(0,234,255,0.08);
    border: 1px solid rgba(0,234,255,0.25);
    padding: 6px 12px;
    border-radius: 20px;
    font-size: 12px;
    transition: 0.3s;
}

.tag:hover {
    background: #00eaff;
    color: #021018;
    transform: scale(1.08);
}

/* ===== Icons ===== */
.icon {
    font-size: 18px;
}
</style>
</head>

<body>

<div class="container">
    <h1>Systems & Decision Toolkit</h1>
    <div class="underline"></div>
    <div class="subtitle">ENGINEERING • ANALYTICS • EXECUTION</div>

    <div class="grid">

        <div class="card">
            <h3><span class="icon">⚙️</span> Programming & Analysis</h3>
            <div class="tags">
                <div class="tag">Python</div>
                <div class="tag">C</div>
                <div class="tag">SQL</div>
                <div class="tag">Excel</div>
            </div>
        </div>

        <div class="card">
            <h3><span class="icon">📊</span> Operations & Supply Chain</h3>
            <div class="tags">
                <div class="tag">Supply Chain Analytics</div>
                <div class="tag">Production Planning</div>
                <div class="tag">Line Balancing</div>
                <div class="tag">Optimization</div>
            </div>
        </div>

        <div class="card">
            <h3><span class="icon">🧩</span> Simulation & Design</h3>
            <div class="tags">
                <div class="tag">SolidWorks</div>
                <div class="tag">ANSYS</div>
                <div class="tag">AutoCAD</div>
                <div class="tag">CATIA</div>
            </div>
        </div>

        <div class="card">
            <h3><span class="icon">📁</span> Data & Business Tools</h3>
            <div class="tags">
                <div class="tag">Excel</div>
                <div class="tag">Google Sheets</div>
                <div class="tag">Canva</div>
                <div class="tag">PowerPoint</div>
            </div>
        </div>

        <div class="card">
            <h3><span class="icon">🔬</span> Engineering Applications</h3>
            <div class="tags">
                <div class="tag">FEA</div>
                <div class="tag">QFD</div>
                <div class="tag">Product Dev</div>
                <div class="tag">Material Selection</div>
            </div>
        </div>

        <div class="card">
            <h3><span class="icon">✍️</span> Communication</h3>
            <div class="tags">
                <div class="tag">Content Writing</div>
                <div class="tag">Storytelling</div>
                <div class="tag">Presentations</div>
            </div>
        </div>

    </div>
</div>

</body>
</html>
